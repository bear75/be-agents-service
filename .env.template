# ============================================
# PO Command Center - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control!

# ============================================
# Email Access (for OpenClaw lead scraping)
# ============================================
# OpenClaw monitors all configured email addresses for leads
# Format: comma-separated list of email:password pairs

# CAIRE.SE emails (AppCaire main product)
EMAIL_1_USER=sales@caire.se
EMAIL_1_PASSWORD=your-app-password-1

EMAIL_2_USER=info@caire.se
EMAIL_2_PASSWORD=your-app-password-2

EMAIL_3_USER=bjorn@caire.se
EMAIL_3_PASSWORD=your-app-password-3

# EIRTECH.AI emails (Ireland/EU market)
EMAIL_4_USER=sales@eirtech.ai
EMAIL_4_PASSWORD=your-app-password-4

EMAIL_5_USER=info@eirtech.ai
EMAIL_5_PASSWORD=your-app-password-5

EMAIL_6_USER=bjorn@eirtech.ai
EMAIL_6_PASSWORD=your-app-password-6

# NACKAHEMTJANST.SE emails (Nacka local market)
EMAIL_7_USER=sales@nackahemtjanst.se
EMAIL_7_PASSWORD=your-app-password-7

EMAIL_8_USER=info@nackahemtjanst.se
EMAIL_8_PASSWORD=your-app-password-8

EMAIL_9_USER=bjorn@nackahemtjanst.se
EMAIL_9_PASSWORD=your-app-password-9

# IMAP/SMTP Configuration (shared across all accounts)
# Update these if using different email providers
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Email filters (comma-separated keywords to identify leads)
EMAIL_LEAD_KEYWORDS=demo,trial,pricing,contact,inquiry,interested,quote,schedule,partnership,integration,boka,offert

# ============================================
# Twitter/X API Credentials
# ============================================
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_SECRET=your-access-secret
TWITTER_BEARER_TOKEN=your-bearer-token

# ============================================
# LinkedIn API Credentials
# ============================================
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret
LINKEDIN_ACCESS_TOKEN=your-access-token
LINKEDIN_REFRESH_TOKEN=your-refresh-token

# ============================================
# Notion API Credentials
# ============================================
NOTION_API_KEY=your-notion-api-key
NOTION_WORKSPACE_ID=your-workspace-id
NOTION_DATABASE_ID=your-database-id

# ============================================
# Claude API (Anthropic)
# ============================================
# Already configured in your system
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================
# GitHub API (for PR automation)
# ============================================
GITHUB_TOKEN=your-github-token
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# ============================================
# Marketing Agent Settings
# ============================================
MARKETING_WAKE_INTERVAL=900  # 15 minutes in seconds
LEAD_SCORE_THRESHOLD=70      # Minimum score for qualified leads
AUTO_EMAIL_ENABLED=false     # Set to true to enable automatic email sending

# ============================================
# Data Storage Paths
# ============================================
DATA_DIR=/Users/bjornevers_MacPro/HomeCare/be-agent-service/.compound-state/data
SESSIONS_DIR=/Users/bjornevers_MacPro/HomeCare/be-agent-service/.compound-state

# ============================================
# Dashboard Settings
# ============================================
DASHBOARD_PORT=3030
POLLING_INTERVAL=3000  # UI polling in milliseconds

# ============================================
# Security Settings
# ============================================
# Set to 'production' to enable stricter security
NODE_ENV=development

# ============================================
# Logging
# ============================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_DIR=/Users/bjornevers_MacPro/HomeCare/be-agent-service/logs
