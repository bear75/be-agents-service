# ============================================
# PO Command Center - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control!

# ============================================
# Email Access (for OpenClaw lead scraping)
# ============================================
# Primary email for lead scraping (monitors contact forms, inquiries, demo requests)
# Recommended: Use a general inbox like info@, contact@, or hello@
EMAIL_USER=info@caire.se
EMAIL_PASSWORD=your-app-specific-password
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Additional email sources (optional - OpenClaw can monitor multiple inboxes)
# Uncomment and configure to scrape from multiple domains:
# EMAIL_USER_2=info@eirtech.ai
# EMAIL_PASSWORD_2=your-app-specific-password-2
# EMAIL_USER_3=info@nackahemtjanst.se
# EMAIL_PASSWORD_3=your-app-specific-password-3

# Email filters (comma-separated keywords to identify leads)
EMAIL_LEAD_KEYWORDS=demo,trial,pricing,contact,inquiry,interested,quote,schedule

# ============================================
# Twitter/X API Credentials
# ============================================
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_SECRET=your-access-secret
TWITTER_BEARER_TOKEN=your-bearer-token

# ============================================
# LinkedIn API Credentials
# ============================================
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret
LINKEDIN_ACCESS_TOKEN=your-access-token
LINKEDIN_REFRESH_TOKEN=your-refresh-token

# ============================================
# Notion API Credentials
# ============================================
NOTION_API_KEY=your-notion-api-key
NOTION_WORKSPACE_ID=your-workspace-id
NOTION_DATABASE_ID=your-database-id

# ============================================
# Claude API (Anthropic)
# ============================================
# Already configured in your system
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================
# GitHub API (for PR automation)
# ============================================
GITHUB_TOKEN=your-github-token
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# ============================================
# Marketing Agent Settings
# ============================================
MARKETING_WAKE_INTERVAL=900  # 15 minutes in seconds
LEAD_SCORE_THRESHOLD=70      # Minimum score for qualified leads
AUTO_EMAIL_ENABLED=false     # Set to true to enable automatic email sending

# ============================================
# Data Storage Paths
# ============================================
DATA_DIR=/Users/bjornevers_MacPro/HomeCare/be-agent-service/.compound-state/data
SESSIONS_DIR=/Users/bjornevers_MacPro/HomeCare/be-agent-service/.compound-state

# ============================================
# Dashboard Settings
# ============================================
DASHBOARD_PORT=3030
POLLING_INTERVAL=3000  # UI polling in milliseconds

# ============================================
# Security Settings
# ============================================
# Set to 'production' to enable stricter security
NODE_ENV=development

# ============================================
# Logging
# ============================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_DIR=/Users/bjornevers_MacPro/HomeCare/be-agent-service/logs
